# distill environment variables -- copy to .env and fill in real values.
# .env is gitignored; NEVER commit real keys.

# Which LLM provider the pipeline uses.
# One of: mock | gemini | anthropic | openai | ollama
# Default: mock (deterministic, no network, no cost -- used by all tests/CI)
DISTILL_PROVIDER=mock

# Optional model override for the selected provider.
# Leave blank to use the provider's default model.
DISTILL_MODEL=

# API key for the Gemini provider (google-genai SDK).
GEMINI_API_KEY=your-key-here

# API key for the Anthropic provider.
ANTHROPIC_API_KEY=your-key-here

# API key for the OpenAI provider.
OPENAI_API_KEY=your-key-here

# Base URL for a local Ollama server (no API key needed).
OLLAMA_BASE_URL=http://localhost:11434

# Minimum critic confidence (0.0-1.0) required before a KnowledgeDoc is
# accepted without a retry. Default: 0.7
DISTILL_CRITIC_THRESHOLD=0.7

# --- Public-demo settings (distill-demo frontend) -- irrelevant if you only
# --- call distill server-to-server or via Swagger. See api/ratelimit.py.

# Comma-separated list of browser origins allowed to call this API via CORS.
# Default: http://localhost:3000
DISTILL_ALLOWED_ORIGINS=http://localhost:3000

# Path to the SQLite file backing the daily rate-limit counters.
# Default: :memory: (fine for local dev/tests; use a real file path in prod
# so counts survive a restart -- see api/ratelimit.py module docstring for
# the Cloud Run persistence caveat).
DISTILL_RATELIMIT_DB_PATH=:memory:

# Per-visitor daily caps and the shared global daily spend ceiling (USD).
DISTILL_RL_DAILY_SINGLE=5
DISTILL_RL_DAILY_COMPARE=1
DISTILL_RL_GLOBAL_BUDGET_USD=2.0
