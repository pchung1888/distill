# distill environment variables -- copy to .env and fill in real values.
# .env is gitignored; NEVER commit real keys.

# Which LLM provider the pipeline uses.
# One of: mock | gemini | anthropic | openai | ollama
# Default: mock (deterministic, no network, no cost -- used by all tests/CI)
DISTILL_PROVIDER=mock

# Optional model override for the selected provider.
# Leave blank to use the provider's default model.
DISTILL_MODEL=

# API key for the Gemini provider (google-genai SDK).
GEMINI_API_KEY=your-key-here

# API key for the Anthropic provider.
ANTHROPIC_API_KEY=your-key-here

# API key for the OpenAI provider.
OPENAI_API_KEY=your-key-here

# Base URL for a local Ollama server (no API key needed).
OLLAMA_BASE_URL=http://localhost:11434

# Minimum critic confidence (0.0-1.0) required before a KnowledgeDoc is
# accepted without a retry. Default: 0.7
DISTILL_CRITIC_THRESHOLD=0.7
